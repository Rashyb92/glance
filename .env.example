# ---------------------------------------------------------------------------
# Glance — configuration. Copy to `.env` and edit. NOTHING here is required to
# run locally: with no edits you get a live, anonymous demo feed on :8787.
# Variables are grouped by what they unlock. "Required in production" means the
# server refuses to start (or that feature stays off) without them.
# ---------------------------------------------------------------------------

# === Core / demo ===========================================================
# Twitch channel to read (no leading '#'). Reading is ANONYMOUS — no keys/OAuth.
GLANCE_CHANNEL=twitch
# Inject synthetic donations/raids/questions so the HUD shows life when the
# channel is quiet. Set 'false' for real chat only.
GLANCE_DEMO=true
# Port the server exposes the scored feed + REST + /admin + /metrics on.
GLANCE_WS_PORT=8787
# How often (ms) the AI summary/recap runs. Lower = more responsive, more calls.
GLANCE_SUMMARY_MS=8000

# === AI (optional) =========================================================
# Leave ANTHROPIC_API_KEY blank to run the deterministic, rule-based salience
# engine with zero external calls. Add a key for Claude-powered summaries.
ANTHROPIC_API_KEY=
GLANCE_AI_MODEL=claude-haiku-4-5-20251001

# === Auth & accounts (REQUIRED IN PRODUCTION) ==============================
# HMAC secret for signing session/member tokens. Without it, every client
# collapses onto the shared `default` tenant — so the server REFUSES TO START
# when NODE_ENV is set to anything but development/test. Use a long random value.
GLANCE_AUTH_SECRET=
# 'production' enables HSTS and the fail-closed auth check above.
NODE_ENV=

# === Durable, multi-instance stores (optional) =============================
# Postgres connection string. When set, every per-tenant store (settings,
# sessions, OAuth tokens, teams, push devices, entitlements, accounts, analytics)
# persists here instead of local files; /ready stays 503 until it's reachable.
DATABASE_URL=
# Redis URL. When set: cross-instance pub/sub bus, fleet-wide AI usage meter, and
# the revocation control channel (logout/revoke-all/member-revoke propagate to
# every instance instantly). Without it, the server runs fine single-instance.
REDIS_URL=

# === Public URLs ===========================================================
# Base URL the server is reachable at — used to build OAuth redirect URIs.
GLANCE_PUBLIC_URL=http://localhost:8787
# Where billing/OAuth flows return the user (your dashboard origin).
GLANCE_DASHBOARD_URL=http://localhost:5174

# === OAuth (optional, per provider) ========================================
# Link a creator's account to read authenticated live chat (and, for Twitch,
# create real clips). Each provider is independent and fails soft until set.
# Provider tokens are encrypted at rest with AES-256-GCM under GLANCE_TOKEN_KEY,
# which is REQUIRED as soon as any provider is linked.
GLANCE_TOKEN_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# === Billing (Stripe, optional) ============================================
# Setting STRIPE_SECRET_KEY turns ON plan enforcement (free/creator/pro limits).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=

# === Push notifications (wearables / phone companion, optional) ============
# Web Push (VAPID) — generate a keypair with `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@glance.app
# Apple Push (iOS native).
APNS_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRODUCTION=
# Firebase Cloud Messaging (Android native).
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# === Admin / support console (optional) ====================================
# Operator auth for /admin and /api/admin/* (separate from tenant auth). Set one
# or both; with neither, the admin API is disabled (fail closed). Use TOKENS for
# per-operator attribution in the audit log.
GLANCE_ADMIN_TOKEN=
# Comma-separated name:token pairs, e.g. alice:s3cret,bob:hunter2
GLANCE_ADMIN_TOKENS=

# === Product analytics (optional) ==========================================
# A content-free activation funnel (signup → activated → engaged → subscribed)
# is ON by default. Set to 1 to disable it entirely.
GLANCE_ANALYTICS_DISABLED=

# === Ops & security ========================================================
# Require this bearer token (or ?token=) to scrape /metrics on a public deploy.
GLANCE_METRICS_TOKEN=
# Comma-separated browser origins allowed to connect (CORS + WS).
GLANCE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# Set to 1 ONLY behind a trusted load balancer, so X-Forwarded-For is trusted.
GLANCE_TRUST_PROXY=
# Per-tenant cooldown (ms) on "clip that" / mark, to respect upstream clip limits.
GLANCE_CLIP_COOLDOWN_MS=15000
# Kick is experimental/unsupported — set to 1 to enable its adapter + viewers.
GLANCE_ENABLE_KICK=
# Logging.
GLANCE_LOG_LEVEL=info
GLANCE_LOG_PRETTY=

# Advanced gateway tuning (sensible defaults; override only if needed):
#   GLANCE_MAX_CLIENTS, GLANCE_MAX_CLIENTS_PER_TENANT, GLANCE_MAX_WS_PAYLOAD,
#   GLANCE_MAX_BODY_BYTES, GLANCE_MAX_BUFFERED, GLANCE_HEADERS_TIMEOUT_MS,
#   GLANCE_REQUEST_TIMEOUT_MS, GLANCE_HTTP_BURST, GLANCE_HTTP_RPS,
#   GLANCE_CONN_BURST, GLANCE_CONN_RPS

# === Frontend (Vite, build-time — set per app, not here) ===================
# Dashboard/HUD/Companion read these at build time:
#   VITE_GLANCE_API_URL, VITE_GLANCE_WS (or VITE_GLANCE_WS_URL), VITE_VAPID_PUBLIC_KEY
# NOTE: VITE_GLANCE_TOKEN is a DEV-ONLY fallback. Do NOT bake a token into a
# production build — users authenticate at runtime via signup/login.

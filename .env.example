# ---------------------------------------------------------------------------
# Glance — local configuration. Copy this file to `.env` and edit as needed.
# Nothing here is required to run: with no edits you get a live demo feed.
# ---------------------------------------------------------------------------

# Twitch channel to read (no leading '#'). Reading is ANONYMOUS — no keys, no
# OAuth, no approval. Set this to any channel that is currently live to see real
# chat flowing through the salience engine.
GLANCE_CHANNEL=twitch

# Inject synthetic donations / raids / questions so the HUD shows life even when
# the chosen channel is quiet or offline. Great for demos. Set to 'false' for
# real chat only.
GLANCE_DEMO=true

# Port the server exposes the live scored feed on (the HUD connects here).
GLANCE_WS_PORT=8787

# ---------------------------------------------------------------------------
# AI (optional). Leave ANTHROPIC_API_KEY blank to run the deterministic,
# rule-based salience engine with zero external calls. Add a key to light up
# Claude-powered chat summaries in AI Assist / Hybrid modes.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GLANCE_AI_MODEL=claude-haiku-4-5-20251001

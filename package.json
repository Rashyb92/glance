{
  "name": "glance",
  "version": "0.1.0",
  "private": true,
  "description": "Glance — the calm, AI-curated heads-up layer for live creators.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "//engines": "Runs on Node >=20.19. Node 20 reaches EOL — use Node 22 LTS or 24 for production; CI runs Node 24.",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "server": "pnpm --filter @glance/server dev",
    "hud": "pnpm --filter @glance/hud dev",
    "dashboard": "pnpm --filter @glance/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.2.6"
  }
}
